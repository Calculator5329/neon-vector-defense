rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in [
          '5329548871,eg@gmail.com',
          '5329548871.eg@gmail.com'
        ];
    }

    function isValidDailyBoard(daily) {
      return daily.matches('^daily-[0-9]{4}-[0-9]{2}-[0-9]{2}$');
    }

    function isValidRunId(runId) {
      return runId.matches('^r_[A-Za-z0-9_-]{8,80}$');
    }

    function isTelemetrySchema(data) {
      return data.schemaVersion in [1, 2];
    }

    function isRunSummary(summary) {
      return summary is map
        && summary.keys().hasAll(['callsign', 'map', 'mapName', 'diff', 'diffName', 'freeplay', 'outcome', 'phase', 'wave', 'kills', 'credits', 'cashEarned', 'leaks', 'coresLeft', 'durationS'])
        && summary.keys().hasOnly(['callsign', 'map', 'mapName', 'diff', 'diffName', 'freeplay', 'outcome', 'phase', 'wave', 'kills', 'credits', 'cashEarned', 'leaks', 'coresLeft', 'durationS', 'daily', 'contractId', 'scoreMultiplierEnd'])
        && summary.callsign is string && summary.callsign.size() <= 20
        && summary.map is string && summary.map.size() <= 30
        && summary.mapName is string && summary.mapName.size() <= 80
        && summary.diff is string && summary.diff.size() <= 30
        && summary.diffName is string && summary.diffName.size() <= 80
        && summary.freeplay is bool
        && summary.outcome in ['victory', 'armistice', 'gameover', 'abandoned']
        && summary.phase is string && summary.phase.size() <= 30
        && summary.wave is int && summary.wave >= 0 && summary.wave <= 10000
        && summary.kills is int && summary.kills >= 0 && summary.kills < 10000000
        && summary.credits is int && summary.credits >= 0 && summary.credits < 100000000
        && summary.cashEarned is int && summary.cashEarned >= 0 && summary.cashEarned < 100000000
        && summary.leaks is int && summary.leaks >= 0 && summary.leaks < 1000000
        && summary.coresLeft is int && summary.coresLeft >= 0 && summary.coresLeft < 1000000
        && summary.durationS is int && summary.durationS >= 0 && summary.durationS < 100000
        && (!('daily' in summary) || isValidDailyBoard(summary.daily))
        && (!('contractId' in summary) || (summary.contractId is string && summary.contractId.size() <= 30))
        && (!('scoreMultiplierEnd' in summary) || (summary.scoreMultiplierEnd is number && summary.scoreMultiplierEnd >= 0 && summary.scoreMultiplierEnd <= 100));
    }

    // public leaderboards: anyone can read. Writes are SERVER-ONLY via the submitScore
    // Cloud Function (Admin SDK, which bypasses rules); direct client writes are blocked.
    // This is the leaderboard-integrity lockdown — scores are validated against a replay
    // and rate-limited server-side before they land here.
    match /boards/{board}/scores/{id} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    // daily freeplay leaderboards: anyone can read. Writes are SERVER-ONLY via the
    // submitDailyScore Cloud Function (Admin SDK).
    match /dailyBoards/{daily}/scores/{id} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    // public sanitized run replays: anyone may fetch by id; listing is admin-only.
    match /runs/{runId} {
      allow get: if true;
      allow list: if isAdmin();
      allow delete: if false;
      allow create: if isValidRunId(runId)
        && request.resource.data.keys().hasAll(['schemaVersion', 'runId', 'replayTokenHash', 'createdAt', 'endedAt', 'build', 'chunkCount', 'eventCount', 'summary', 'setup', 'events', 'snapshots', 'final'])
        && request.resource.data.keys().hasOnly(['schemaVersion', 'runId', 'replayTokenHash', 'createdAt', 'endedAt', 'build', 'chunkCount', 'eventCount', 'summary', 'setup', 'events', 'snapshots', 'final'])
        && isTelemetrySchema(request.resource.data)
        && request.resource.data.runId == runId
        && request.resource.data.replayTokenHash is string && request.resource.data.replayTokenHash.matches('^[a-f0-9]{64}$')
        && request.resource.data.createdAt is int && request.resource.data.createdAt > 0
        && request.resource.data.endedAt is int && request.resource.data.endedAt >= request.resource.data.createdAt
        && request.resource.data.build is string && request.resource.data.build.size() <= 30
        && request.resource.data.chunkCount is int && request.resource.data.chunkCount >= 0 && request.resource.data.chunkCount <= 100
        && request.resource.data.eventCount is int && request.resource.data.eventCount >= 0 && request.resource.data.eventCount <= 100000
        && isRunSummary(request.resource.data.summary)
        && request.resource.data.setup is map
        && request.resource.data.final is map
        && request.resource.data.events is list && request.resource.data.events.size() <= 650
        && request.resource.data.snapshots is list && request.resource.data.snapshots.size() <= 120;

      match /chunks/{chunkId} {
        allow get: if true;
        allow list: if isAdmin();
        allow delete: if false;
        allow create: if isValidRunId(runId)
          && chunkId.matches('^c[0-9]{1,4}$')
          && request.resource.data.keys().hasAll(['schemaVersion', 'runId', 'chunk', 'events'])
          && request.resource.data.keys().hasOnly(['schemaVersion', 'runId', 'chunk', 'events'])
          && isTelemetrySchema(request.resource.data)
          && request.resource.data.runId == runId
          && request.resource.data.chunk is int && request.resource.data.chunk >= 0 && request.resource.data.chunk <= 9999
          && request.resource.data.events is list && request.resource.data.events.size() <= 650;
      }
    }

    // private engagement analytics: players write; only admins can read.
    match /runAnalytics/{runId} {
      allow read: if isAdmin();
      allow update, delete: if false;
      allow create: if isValidRunId(runId)
        && isTelemetrySchema(request.resource.data)
        && (
          (
            request.resource.data.schemaVersion == 1
            && request.resource.data.keys().hasAll(['schemaVersion', 'runId', 'uid', 'createdAt', 'endedAt', 'build', 'summary', 'onboarding', 'abandonment', 'difficulty', 'economy', 'towerInterest', 'progression', 'leaderboard', 'attention', 'performance'])
            && request.resource.data.keys().hasOnly(['schemaVersion', 'runId', 'uid', 'createdAt', 'endedAt', 'build', 'summary', 'onboarding', 'abandonment', 'difficulty', 'economy', 'towerInterest', 'progression', 'leaderboard', 'attention', 'performance'])
          )
          || (
            request.resource.data.schemaVersion == 2
            && request.resource.data.keys().hasAll(['schemaVersion', 'runId', 'uid', 'createdAt', 'endedAt', 'build', 'summary', 'onboarding', 'abandonment', 'difficulty', 'economy', 'menu', 'controls', 'combat', 'placement', 'assistance', 'freeplay', 'towerInterest', 'progression', 'leaderboard', 'attention', 'performance'])
            && request.resource.data.keys().hasOnly(['schemaVersion', 'runId', 'uid', 'createdAt', 'endedAt', 'build', 'summary', 'onboarding', 'abandonment', 'difficulty', 'economy', 'menu', 'controls', 'combat', 'placement', 'assistance', 'freeplay', 'towerInterest', 'progression', 'leaderboard', 'attention', 'performance'])
          )
        )
        && request.resource.data.runId == runId
        && request.resource.data.uid is string && request.resource.data.uid.size() >= 6 && request.resource.data.uid.size() <= 40
        && request.resource.data.createdAt is int && request.resource.data.createdAt > 0
        && request.resource.data.endedAt is int && request.resource.data.endedAt >= request.resource.data.createdAt
        && request.resource.data.build is string && request.resource.data.build.size() <= 30
        && isRunSummary(request.resource.data.summary)
        && request.resource.data.onboarding is map
        && request.resource.data.abandonment is map
        && request.resource.data.difficulty is map
        && request.resource.data.economy is map
        && (!('menu' in request.resource.data) || request.resource.data.menu is map)
        && (!('controls' in request.resource.data) || request.resource.data.controls is map)
        && (!('combat' in request.resource.data) || request.resource.data.combat is map)
        && (!('placement' in request.resource.data) || request.resource.data.placement is map)
        && (!('assistance' in request.resource.data) || request.resource.data.assistance is map)
        && (!('freeplay' in request.resource.data) || request.resource.data.freeplay is map)
        && request.resource.data.towerInterest is map
        && request.resource.data.progression is map
        && request.resource.data.leaderboard is map
        && request.resource.data.attention is map
        && request.resource.data.performance is map;
    }

    // live private run checkpoints: compact, append-only chunks for admin dashboards.
    match /runCheckpoints/{runId} {
      allow read: if isAdmin();
      allow write: if false;

      match /chunks/{chunkId} {
        allow read: if isAdmin();
        allow update, delete: if false;
        allow create: if isValidRunId(runId)
          && chunkId.matches('^c[0-9]{1,6}$')
          && request.resource.data.keys().hasAll(['schemaVersion', 'runId', 'uid', 'chunk', 'reason', 'createdAt', 'build', 'summary', 'performance', 'attention', 'counters', 'recentEvents', 'latestSnapshot'])
          && request.resource.data.keys().hasOnly(['schemaVersion', 'runId', 'uid', 'chunk', 'reason', 'createdAt', 'build', 'summary', 'performance', 'attention', 'counters', 'recentEvents', 'latestSnapshot'])
          && isTelemetrySchema(request.resource.data)
          && request.resource.data.runId == runId
          && request.resource.data.uid is string && request.resource.data.uid.size() >= 6 && request.resource.data.uid.size() <= 40
          && request.resource.data.chunk is int && request.resource.data.chunk >= 0 && request.resource.data.chunk <= 999999
          && request.resource.data.reason is string && request.resource.data.reason.size() <= 30
          && request.resource.data.createdAt is int && request.resource.data.createdAt > 0
          && request.resource.data.build is string && request.resource.data.build.size() <= 30
          && isRunSummary(request.resource.data.summary)
          && request.resource.data.performance is map
          && request.resource.data.attention is map
          && request.resource.data.counters is map
          && request.resource.data.recentEvents is list && request.resource.data.recentEvents.size() <= 32
          && (request.resource.data.latestSnapshot == null || request.resource.data.latestSnapshot is map);
      }
    }

    // player feedback: SERVER-ONLY creates via submitFeedback. Admins can read/reply
    // after Google sign-in; players fetch replies through a private token callable.
    match /feedback/{id} {
      allow get: if isAdmin();
      allow list: if isAdmin();
      allow delete: if false;
      allow create: if false;
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'reply', 'replyTs', 'repliedBy'])
        && request.resource.data.keys().hasOnly(['uid', 'text', 'ts', 'ctx', 'status', 'replyTokenHash', 'serverTs', 'reply', 'replyTs', 'repliedBy'])
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.text == resource.data.text
        && request.resource.data.ts == resource.data.ts
        && request.resource.data.ctx == resource.data.ctx
        && (!('replyTokenHash' in resource.data) || request.resource.data.replyTokenHash == resource.data.replyTokenHash)
        && (!('serverTs' in resource.data) || request.resource.data.serverTs == resource.data.serverTs)
        && (!('status' in request.resource.data) || request.resource.data.status in ['open', 'replied', 'archived'])
        && (!('reply' in request.resource.data) || (request.resource.data.reply is string && request.resource.data.reply.size() <= 2000))
        && (!('replyTs' in request.resource.data) || request.resource.data.replyTs is int)
        && (!('repliedBy' in request.resource.data) || (request.resource.data.repliedBy is string && request.resource.data.repliedBy.size() <= 120));
    }

    // anonymous gameplay telemetry: player append-only, admin-read only.
    match /telemetry/{id} {
      allow read: if isAdmin();
      allow update, delete: if false;
      allow create: if request.resource.data.keys().hasOnly(['uid', 'ts', 'kind', 'map', 'diff', 'wave', 'kills', 'cash', 'won', 'freeplay', 'durationS', 'leaks', 'coresLeft', 'towers', 'dmg', 'abilities', 'build'])
        && request.resource.data.keys().hasAll(['uid', 'ts', 'kind', 'map', 'diff', 'wave', 'kills', 'cash', 'won', 'freeplay', 'durationS'])
        && request.resource.data.uid is string
        && request.resource.data.uid.size() >= 6 && request.resource.data.uid.size() <= 40
        && request.resource.data.ts is int && request.resource.data.ts > 0
        && request.resource.data.kind is string && request.resource.data.kind.size() <= 30
        && request.resource.data.map is string && request.resource.data.map.size() <= 30
        && request.resource.data.diff is string && request.resource.data.diff.size() <= 30
        && request.resource.data.wave is int && request.resource.data.wave >= 0 && request.resource.data.wave <= 10000
        && request.resource.data.kills is int && request.resource.data.kills >= 0 && request.resource.data.kills < 10000000
        && request.resource.data.cash is int && request.resource.data.cash >= 0 && request.resource.data.cash < 100000000
        && request.resource.data.won is bool
        && request.resource.data.freeplay is bool
        && request.resource.data.durationS is int && request.resource.data.durationS >= 0 && request.resource.data.durationS < 100000
        && (!('leaks' in request.resource.data) || (request.resource.data.leaks is int && request.resource.data.leaks >= 0 && request.resource.data.leaks < 1000000))
        && (!('coresLeft' in request.resource.data) || (request.resource.data.coresLeft is int && request.resource.data.coresLeft >= 0 && request.resource.data.coresLeft < 1000000))
        && (!('towers' in request.resource.data) || (request.resource.data.towers is string && request.resource.data.towers.size() <= 200))
        && (!('dmg' in request.resource.data) || (request.resource.data.dmg is string && request.resource.data.dmg.size() <= 120))
        && (!('abilities' in request.resource.data) || (request.resource.data.abilities is int && request.resource.data.abilities >= 0 && request.resource.data.abilities < 100000))
        && (!('build' in request.resource.data) || (request.resource.data.build is string && request.resource.data.build.size() <= 30));
    }

    // remote balance overrides: public read (PII-free gameplay tuning), admin write only.
    // The client clamps every value to [0.25, 4] and falls back to identity, so rules only
    // gate WHO writes + the coarse shape.
    match /config/balance {
      allow get: if true;
      allow list: if false;
      allow write: if isAdmin()
        && request.resource.data.keys().hasOnly(['version', 'income', 'diffs', 'enemies', 'towers'])
        && (!('version' in request.resource.data) || (request.resource.data.version is string && request.resource.data.version.size() <= 30))
        && (!('income' in request.resource.data) || request.resource.data.income is map)
        && (!('diffs' in request.resource.data) || request.resource.data.diffs is map)
        && (!('enemies' in request.resource.data) || request.resource.data.enemies is map)
        && (!('towers' in request.resource.data) || request.resource.data.towers is map);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
