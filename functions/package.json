{
  "name": "functions",
  "description": "Cloud Functions for Lantern 7 (leaderboard integrity + data deletion)",
  "type": "module",
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "scripts": {
    "prebuild": "node ../scripts/bundle-resim.mjs",
    "build": "tsc",
    "test": "npm run build && node --test test/*.test.mjs",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "dependencies": {
    "firebase-admin": "14.2.0",
    "firebase-functions": "7.3.0"
  },
  "devDependencies": {
    "typescript": "~6.0.3"
  },
  "private": true,
  "overrides": {
    "gaxios": {
      "uuid": "^11.1.1"
    },
    "teeny-request": {
      "uuid": "^11.1.1"
    }
  }
}
