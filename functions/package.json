{
  "name": "functions",
  "description": "Cloud Functions for Neon Vector Defense (leaderboard integrity + data deletion)",
  "type": "module",
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "scripts": {
    "prebuild": "node ../scripts/bundle-resim.mjs",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "dependencies": {
    "firebase-admin": "^13.0.0",
    "firebase-functions": "^6.1.0"
  },
  "devDependencies": {
    "typescript": "~6.0.3"
  },
  "private": true
}
