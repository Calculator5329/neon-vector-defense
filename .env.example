# Optional in-game AI helper endpoint. Omit to hide the AI widget.
VITE_AI_HELP_URL=

# Optional Firebase App Check client token plumbing.
VITE_FIREBASE_APPCHECK_SITE_KEY=

# Local Vite dev only. Do not use a debug token in production builds.
VITE_FIREBASE_APPCHECK_DEBUG_TOKEN=

# Optional portal build flavor. Leave blank for normal Firebase Hosting builds.
# Supported values: crazygames, poki
VITE_PORTAL=

# Generation scripts only. Never expose this through VITE_* variables.
OPENROUTER_API_KEY=

# Cloud Functions runtime only. Flip after production App Check token flow is clean.
ENFORCE_APP_CHECK=false

# GitHub Actions/manual deploy helpers.
FIREBASE_PROJECT_ID=neon-vector-defense-7
FIREBASE_WEB_APP_ID=
FIREBASE_WEB_API_KEY=
